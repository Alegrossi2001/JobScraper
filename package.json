{
  "name": "jobscraper",
  "version": "2.0.0",
  "description": "Automated job scraper for Poznan SWE roles → Notion",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "setup": "tsx src/setup.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "cleanup": "tsx src/cleanup.ts",
    "apply": "tsx src/apply/listNewJobs.ts",
    "linkedin:setup": "tsx src/linkedin/createOutreachDb.ts",
    "linkedin:companies": "tsx src/linkedin/getCompanies.ts",
    "linkedin:search": "tsx src/linkedin/apolloSearch.ts"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "axios": "^1.7.7",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
